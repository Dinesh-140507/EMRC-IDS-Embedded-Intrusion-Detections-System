// =============================================
// CC1101 CALIBRATION
// =============================================
void calibrateCC1101() {
  Serial.println("Calibrating CC1101...");

  SPI.begin();  // ← explicit SPI for CC1101
  ELECHOUSE_cc1101.SetRx();

  int worst_rssi = -120;
  for (int i = 0; i < NUM_BANDS; i++) {
    yield();
    ELECHOUSE_cc1101.setMHZ(cc1101_bands[i]);
    delay(10);
    for (int j = 0; j < 5; j++) {
      int rssi = ELECHOUSE_cc1101.getRssi();
      Serial.printf("  %.0f MHz sample %d: %d dBm\n",
                    cc1101_bands[i], j, rssi);  // ← debug each sample
      if (rssi > worst_rssi) worst_rssi = rssi;
      delay(5);
    }
  }

  cc1101_noise_floor = worst_rssi - 5;
  Serial.printf("CC1101 noise floor : %d dBm\n", worst_rssi);
  Serial.printf("CC1101 threshold   : %d dBm\n", cc1101_noise_floor);

  SPI.end();
  delay(20);
 SPI.begin(); 
  delay(20);
}

