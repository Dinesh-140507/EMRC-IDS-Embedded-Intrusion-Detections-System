// =============================================
// TFT — DRAW A SCORE BAR
// x,y = top-left of bar area
// w,h = bar dimensions
// value = current score (0-10)
// =============================================
void drawBar(int x, int y, int w, int h,
             int value, int maxVal, uint16_t colour) {
  // Background
  tft.fillRect(x, y, w, h, CLR_BAR_BG);

  // Filled portion
  int filled = map(value, 0, maxVal, 0, w);
  filled = constrain(filled, 0, w);
  if (filled > 0) {
    tft.fillRect(x, y, filled, h, colour);
  }

  // Border
  tft.drawRect(x, y, w, h, CLR_GREY);
}

// =============================================
// TFT — DRAW THREAT BADGE (colour coded)
// =============================================
void drawThreatBadge(float score) {
  uint16_t colour;
  const char* label;

  if (score <= 3) {
    colour = CLR_GREEN;
    label  = "  LOW   ";
  } else if (score <= 6) {
    colour = CLR_YELLOW;
    label  = " MEDIUM ";
  } else {
    colour = CLR_RED;
    label  = "  HIGH  ";
  }

  // Badge background
  tft.fillRoundRect(100, 195, 120, 22, 4, colour);
  tft.setTextColor(CLR_BG);
  tft.setTextSize(2);
  tft.setCursor(108, 200);
  tft.print(label);
  tft.setTextSize(1);
}

