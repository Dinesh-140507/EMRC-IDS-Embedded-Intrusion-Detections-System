// =============================================
// SETUP
// =============================================
void setup() {
  Serial.begin(115200);
  delay(500);
  SPI.begin();

  // ── TFT first ──────────────────────────────
  tft.begin();
  tft.setRotation(1);
  tft.fillScreen(CLR_BG);
  tft.setTextColor(CLR_CYAN);
  tft.setTextSize(3);
  tft.setCursor(30, 80);
  tft.print("EMRC-IDS");
  tft.setTextColor(CLR_WHITE);
  tft.setTextSize(1);
  tft.setCursor(20, 130);
  tft.print("Please wait...");

  // ── All sensor inits — NO TFT CALLS HERE ───
  pinMode(MCP_INT, INPUT_PULLUP);
  bool mcp_ok = (CAN.begin(MCP_ANY, CAN_500KBPS, MCP_8MHZ) == CAN_OK);
  if (mcp_ok) {
    CAN.setMode(MCP_NORMAL);
    Serial.println("MCP2515 OK");
  } else {
    Serial.println("MCP2515 FAILED");
    while (1);
  }
  Serial.println("Testing NRF24...");
delay(100);   

  int nrf_attempts = 0;
  bool nrf_ok = false;
  while (!radio.begin()) {
    nrf_attempts++;
    Serial.printf("NRF24 attempt %d...\n", nrf_attempts);
    delay(500);
    if (nrf_attempts >= 5) break;
  }
  nrf_ok = (nrf_attempts < 5);
  if (nrf_ok) {
    radio.setAutoAck(false);
    radio.startListening();
    Serial.println("NRF24 OK");
     
  } else {
    Serial.println("NRF24 FAILED");
  }
  WiFi.mode(WIFI_AP);
WiFi.softAP("EMRC-TEST", "", 6);  // channel 6 = NRF24 ch 26
testServer.begin();
Serial.println("Test server started");

  ELECHOUSE_cc1101.setSpiPin(18, 19, 23, CC1101_CS);
  ELECHOUSE_cc1101.Init();
  ELECHOUSE_cc1101.SetRx();
  Serial.println("CC1101 OK");
  calibrateCC1101();
   Serial.println("Calibration done");

   // ── Reinitialise SPI after CC1101 ──────────
  SPI.end();                    // ← release SPI
  delay(100);
  SPI.begin(18, 19, 23, -1);   // ← restart SPI with correct pins
  delay(100);
  Serial.println("SPI reinit done");

  // ── Now safe to draw on TFT ────────────────
  Serial.println("Starting TFT draw...");
  tft.begin();                  // ← reinit TFT after SPI restart
  tft.setRotation(1);
  tft.fillScreen(CLR_BG);
  Serial.println("fillScreen done");

  // ── ALL INITS DONE — now safe to draw ──────
  // Show init results on TFT after all SPI inits complete
  tft.fillScreen(CLR_BG);
  tft.setTextColor(CLR_CYAN);
  tft.setTextSize(2);
  tft.setCursor(60, 20);
  tft.print("EMRC-IDS");

  tft.setTextSize(1);
  int y = 60;

  tft.setCursor(20, y); y += 16;
  tft.setTextColor(mcp_ok ? CLR_GREEN : CLR_RED);
  tft.print("MCP2515  : ");
  tft.print(mcp_ok ? "OK" : "FAILED");

  tft.setCursor(20, y); y += 16;
  tft.setTextColor(nrf_ok ? CLR_GREEN : CLR_RED);
  tft.print("NRF24    : ");
  tft.print(nrf_ok ? "OK" : "FAILED");

  tft.setCursor(20, y); y += 16;
  tft.setTextColor(CLR_GREEN);
  tft.print("CC1101   : OK");

  tft.setCursor(20, y); y += 16;
  tft.setTextColor(CLR_YELLOW);
  tft.printf("Threshold: %d dBm", cc1101_noise_floor);

  tft.setCursor(20, y + 10);
  tft.setTextColor(CLR_WHITE);
  tft.print("Starting in 2 seconds...");

  delay(2000);  // safe here — all SPI inits complete

  // ── Draw main dashboard ─────────────────────
  drawStaticUI();
  setAlert("System started");

  // ── Timers ─────────────────────────────────
  learning_start     = millis();
  flood_window_start = millis();
  last_decay         = millis();
  last_serial_print  = millis();
  last_tft_update    = millis();

  Serial.println("=== EMRC-IDS STARTED ===\n");
}


// =============================================
// LOOP
// =============================================
void loop() {
  handleCAN();
  handleNRF();
  handleCC1101();
  handleSerialCommands();
  decayScores();
  calculateThreat();
  

  // Update TFT every 500ms
  if (millis() - last_tft_update > 500) {
    updateDashboard();
    last_tft_update = millis();
  }

  printStatus();
}

// =============================================
// CAN HANDLER
// =============================================
void handleCAN() {

  // ── TIMEOUT CHECK — MUST BE OUTSIDE INT CHECK ──
  if (learning_mode && millis() - learning_start > LEARNING_TIME) {
    learning_mode = false;
    Serial.printf("Learning done — %d IDs learned\n", idCount);
    setAlert("Detection active");
  }

  // ── FRAME READING ───────────────────────────────
  if (!digitalRead(MCP_INT)) {
    unsigned long id;
    byte ext, len;
    byte buf[8];
    CAN.readMsgBuf(&id, &ext, &len, buf);

    flood_count++;
    unsigned long flood_elapsed = millis() - flood_window_start;
    if (flood_elapsed >= 1000) {
      float fps = (float)flood_count / (flood_elapsed / 1000.0);
      if (fps > 200 && !learning_mode) {
        char msg[32];
        snprintf(msg, sizeof(msg), "CAN Flood %.0f fps", fps);
        setAlert(msg);
        can_score = min(10, can_score + 4);
      }
      flood_count = 0;
      flood_window_start = millis();
    }

    if (learning_mode) {
      bool exists = false;
      for (int i = 0; i < idCount; i++) {
        if (learnedIDs[i] == id) { exists = true; break; }
      }
      if (!exists && idCount < MAX_IDS) {
        learnedIDs[idCount++] = id;
        Serial.printf("Learned ID: 0x%03X\n", id);
      }
      return;
    }

    bool known = false;
    for (int i = 0; i < idCount; i++) {
      if (learnedIDs[i] == id) { known = true; break; }
    }
    if (!known) {
      char msg[32];
      snprintf(msg, sizeof(msg), "Unknown ID 0x%03X", (unsigned int)id);
      Serial.printf("⚠ %s\n", msg);
      setAlert(msg);
      can_score = min(10, can_score + 3);
    }

    if (has_last_data && known) {
      for (int i = 0; i < len; i++) {
        int jump = abs((int)buf[i] - (int)last_data[i]);
        if (jump > 80) {
          char msg[32];
          snprintf(msg, sizeof(msg), "Val Jump 0x%03X +%d",
                   (unsigned int)id, jump);
          Serial.printf("⚠ %s\n", msg);
          setAlert(msg);
          can_score = min(10, can_score + 3);
          break;
        }
      }
    }
    memcpy(last_data, buf, len);
    has_last_data = true;
  }
}

// =============================================
// NRF24 HANDLER
// =============================================
void handleNRF() {
  int raw_count = 0;

  for (int ch = 0; ch < 125; ch++) {
    radio.setChannel(ch);
    radio.startListening();
    for (int s = 0; s < 3; s++) {
      delayMicroseconds(300);
      if (radio.testCarrier()) { raw_count++; break; }
    }
    radio.stopListening();
    if (ch % 25 == 0) yield();
  }

  radio.startListening();

  nrf_cumulative += raw_count;
  unsigned long elapsed = millis() - nrf_window_start;

  Serial.printf("NRF24: %d ch | total: %d | elapsed: %lums\n",
                raw_count, nrf_cumulative, elapsed);

  // Reset window based on time elapsed not fixed 5000ms
  if (elapsed >= 3000) {                    // ← reduce to 3 seconds
    Serial.printf("Window reset — total was: %d\n", nrf_cumulative);

    // More aggressive mapping — 5 detections = score 5
    rf_score_24 = map(nrf_cumulative, 0, 10, 0, 10);
    rf_score_24 = max(0, min(10, rf_score_24));

    if (nrf_cumulative >= 3) {
      char msg[32];
      snprintf(msg, sizeof(msg), "RF 2.4G %d hits", nrf_cumulative);
      setAlert(msg);
      Serial.printf("⚠ RF 2.4G: %d hits → score %d\n",
                    nrf_cumulative, rf_score_24);
    }

    nrf_cumulative   = 0;                   // ← reset counter
    nrf_window_start = millis();            // ← reset timer
  }
}

// =============================================
// CC1101 HANDLER
// =============================================
void handleCC1101() {
  rf_score_sub = 0;
  bool alert_printed = false;

  // Explicitly take SPI control for CC1101
  SPI.begin(18, 19, 23, CC1101_CS);
  ELECHOUSE_cc1101.SetRx();        // ← re-enter RX mode before reading

  for (int i = 0; i < NUM_BANDS; i++) {
    ELECHOUSE_cc1101.setMHZ(cc1101_bands[i]);
    delay(10);                     // ← increase settle time

    int rssi_sum = 0;
    for (int j = 0; j < 3; j++) {
      rssi_sum += ELECHOUSE_cc1101.getRssi();
      delay(5);
    }
    int rssi_avg = rssi_sum / 3;

    Serial.printf("  %.0f MHz → %d dBm\n", cc1101_bands[i], rssi_avg);

    if (rssi_avg > cc1101_noise_floor) {
      rf_score_sub++;
      if (!alert_printed) {
        char msg[32];
        snprintf(msg, sizeof(msg), "SubGHz %.0fMHz %ddBm",
                 cc1101_bands[i], rssi_avg);
        setAlert(msg);
        alert_printed = true;
      }
    }
  }

  // Hand SPI back with full reinit
  SPI.end();
  delay(20);
  SPI.begin(); 
  delay(20);

  rf_score_sub = map(rf_score_sub, 0, NUM_BANDS, 0, 10);
  rf_score_sub = max(0, min(10, rf_score_sub));
}

// =============================================
// SERIAL COMMANDS
// u=unknown ID  f=flood  j=jump
// r=reset       s=status c=CC1101 debug
// =============================================
void handleSerialCommands() {
  if (!Serial.available()) return;
  char cmd = Serial.read();

  switch (cmd) {
    case 'u':
      if (!learning_mode) {
        can_score = min(10, can_score + 3);
        setAlert("TEST: Unknown ID");
        Serial.println("[TEST] Unknown ID → CAN +3");
      }
      break;
    case 'f':
      if (!learning_mode) {
        can_score = min(10, can_score + 4);
        setAlert("TEST: CAN Flood");
        Serial.println("[TEST] Flood → CAN +4");
      }
      break;
    case 'j':
      if (!learning_mode) {
        can_score = min(10, can_score + 3);
        setAlert("TEST: Value Jump");
        Serial.println("[TEST] Value jump → CAN +3");
      }
      break;
    case 'r':
      can_score = rf_score_24 = rf_score_sub = 0;
      threat_score = 0;
      setAlert("Scores reset");
      Serial.println("All scores reset");
      break;
    case 's':
      last_serial_print = 0;
      break;
    case 'c':
      Serial.println("── CC1101 Raw RSSI ──");
      for (int i = 0; i < NUM_BANDS; i++) {
        ELECHOUSE_cc1101.setMHZ(cc1101_bands[i]);
        delay(10);
        Serial.printf("  %.0f MHz → %d dBm\n",
                      cc1101_bands[i], ELECHOUSE_cc1101.getRssi());
      }
      Serial.printf("  Threshold : %d dBm\n", cc1101_noise_floor);
      break;
  }
}

// =============================================
// SCORE DECAY
// =============================================
void decayScores() {
  if (millis() - last_tft_update > 1000) {
  prev_rf24  = -1;  // force redraw
  prev_sub   = -1;
  prev_can   = -1;
  updateDashboard();
  last_tft_update = millis();
}
}

// =============================================
// THREAT ENGINE
// =============================================
void calculateThreat() {
  threat_score = (0.4 * rf_score_24)
               + (0.4 * rf_score_sub)
               + (0.2 * can_score);
  threat_score = max(0.0f, min(10.0f, threat_score));
}

const char* getThreatLevel() {
  if (threat_score <= 3) return "LOW";
  if (threat_score <= 6) return "MEDIUM";
  return "HIGH";
}

// =============================================
// SERIAL STATUS PRINT — every 2 seconds
// =============================================
void printStatus() {
  if (millis() - last_serial_print > 2000) {
    Serial.println("─────────────────────────────");
    Serial.printf("Mode         : %s\n",
                  learning_mode ? "LEARNING" : "DETECTION");
    Serial.printf("RF 2.4G      : %d / 10\n", rf_score_24);
    Serial.printf("RF SubGHz    : %d / 10\n", rf_score_sub);
    Serial.printf("CAN Score    : %d / 10\n", can_score);
    Serial.printf("Threat Score : %.1f / 10\n", threat_score);
    Serial.printf("Threat Level : %s\n", getThreatLevel());
    Serial.printf("Last Alert   : %s\n", last_alert);
    Serial.println("─────────────────────────────\n");
    last_serial_print = millis();
  }
}
